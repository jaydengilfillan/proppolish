# Copy this file to .env.local and paste your own FAL API key.
#   cp .env.example .env.local
#
# Get a key at https://fal.ai  ->  Dashboard  ->  Keys.
# This is the ONLY credential the app needs. It is used server-side only
# and is never exposed to the browser.
FAL_KEY=

# Optional: enables the ChatGPT (OpenAI gpt-image-2) option on the Enhance tab.
# Get a key at https://platform.openai.com -> API keys.
# Also used server-side only, never exposed to the browser.
# If left blank, the Enhance tab still works with Nano Banana only.
OPENAI_API_KEY=
